<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>NJsonSchema</id>
    <version>11.6.1</version>
    <authors>Rico Suter</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>NuGetIcon.png</icon>
    <readme>README.md</readme>
    <projectUrl>http://njsonschema.org/</projectUrl>
    <description>JSON Schema reader, generator and validator for .NET</description>
    <copyright>Copyright © Rico Suter, 2025</copyright>
    <tags>json schema validation generator .net</tags>
    <repository type="git" url="https://github.com/RicoSuter/NJsonSchema" commit="ac2ba4ab9faaea3fb5adff784b99d73d70f6bdb1" />
    <dependencies>
      <group targetFramework=".NETFramework4.6.2">
        <dependency id="NJsonSchema.Annotations" version="11.6.1" exclude="Build,Analyzers" />
        <dependency id="Namotion.Reflection" version="3.5.0" exclude="Build,Analyzers" />
        <dependency id="Newtonsoft.Json" version="13.0.3" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="9.0.9" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net8.0">
        <dependency id="NJsonSchema.Annotations" version="11.6.1" exclude="Build,Analyzers" />
        <dependency id="Namotion.Reflection" version="3.5.0" exclude="Build,Analyzers" />
        <dependency id="Newtonsoft.Json" version="13.0.3" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="NJsonSchema.Annotations" version="11.6.1" exclude="Build,Analyzers" />
        <dependency id="Namotion.Reflection" version="3.5.0" exclude="Build,Analyzers" />
        <dependency id="Newtonsoft.Json" version="13.0.3" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="9.0.9" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>