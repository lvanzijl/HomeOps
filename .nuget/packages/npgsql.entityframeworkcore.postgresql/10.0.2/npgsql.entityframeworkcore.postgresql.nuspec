<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Npgsql.EntityFrameworkCore.PostgreSQL</id>
    <version>10.0.2</version>
