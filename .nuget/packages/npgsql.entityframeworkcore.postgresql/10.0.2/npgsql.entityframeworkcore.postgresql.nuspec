    <readme>README.md</readme>
    <projectUrl>https://github.com/npgsql/efcore.pg</projectUrl>
    <description>PostgreSQL/Npgsql provider for Entity Framework Core.</description>
    <copyright>Copyright 2025 © The Npgsql Development Team</copyright>
    <tags>npgsql postgresql postgres Entity Framework Core entity-framework-core ef efcore orm sql</tags>
