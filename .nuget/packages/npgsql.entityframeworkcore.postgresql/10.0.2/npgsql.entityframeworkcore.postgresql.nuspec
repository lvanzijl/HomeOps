        <dependency id="Microsoft.EntityFrameworkCore" version="[10.0.4, 11.0.0)" include="All" />
        <dependency id="Microsoft.EntityFrameworkCore.Relational" version="[10.0.4, 11.0.0)" include="All" />
        <dependency id="Npgsql" version="10.0.3" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>