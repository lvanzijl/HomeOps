COMPOSE_PROJECT_NAME=familyboard
FAMILYBOARD_IMAGE_REPOSITORY=familyboard-app
FAMILYBOARD_IMAGE_TAG=dev
FAMILYBOARD_HOST_PORT=8080
FAMILYBOARD_ASPNETCORE_ENVIRONMENT=Production
FAMILYBOARD_APP_DATA_PATH=/volume1/docker/familyboard/data/app
FAMILYBOARD_POSTGRES_DATA_PATH=/volume1/docker/familyboard/data/postgres
FAMILYBOARD_DB_NAME=homeops
FAMILYBOARD_DB_USER=homeops
FAMILYBOARD_DB_PASSWORD=change-this-password
FAMILYBOARD_CALENDAR_SNAPSHOT_PATH=/app/data/calendar-restore-snapshots
